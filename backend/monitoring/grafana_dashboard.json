{
  "title": "SPICE Observability - Runtime and Error Taxonomy",
  "uid": "spice-observability-runtime",
  "schemaVersion": 38,
  "version": 1,
  "editable": true,
  "refresh": "30s",
  "timezone": "browser",
  "tags": [
    "spice",
    "otel",
    "error-taxonomy",
    "runtime"
  ],
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "refresh": 1,
        "query": "label_values(spice_http_requests_total, service)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(spice_http_requests_total{service=~\"$service\"}[5m])) by (service, status_code)",
          "legendFormat": "{{service}} {{status_code}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Latency p95 (s)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(spice_http_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, service))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Enterprise Error Rate by Code",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(12, sum(rate(spice_errors_total{service=~\"$service\"}[5m])) by (service, enterprise_code, code, http_status))",
          "legendFormat": "{{service}} {{enterprise_code}}/{{code}} ({{http_status}})"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Enterprise Error Rate by Class and Domain",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(spice_errors_total{service=~\"$service\"}[5m])) by (service, enterprise_class, enterprise_domain)",
          "legendFormat": "{{service}} {{enterprise_class}}/{{enterprise_domain}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "5xx Error Share",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(spice_errors_total{service=~\"$service\", http_status=~\"5..\"}[5m])) by (service, enterprise_code)",
          "legendFormat": "{{service}} {{enterprise_code}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Runtime Fallback Rate",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(spice_runtime_fallback_total{service=~\"$service\"}[5m])) by (service, zone, operation, error_code)",
          "legendFormat": "{{service}} {{zone}} {{operation}}/{{error_code}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Enterprise Errors (1h)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spice_errors_total{service=~\"$service\"}[1h]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Runtime Fallbacks (1h)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 8,
        "y": 24,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spice_runtime_fallback_total{service=~\"$service\"}[1h]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "5xx Requests (1h)",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 16,
        "y": 24,
        "w": 8,
        "h": 5
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(spice_http_requests_total{service=~\"$service\", status_code=~\"5..\"}[1h]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Observability Signal Active",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(spice_observability_signal_active{service=~\"$service\"}) by (service, signal)",
          "legendFormat": "{{service}} {{signal}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Observability Pipeline Availability",
      "datasource": "Prometheus",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max(up{job=\"spice-services\"})",
          "legendFormat": "spice-services up"
        },
        {
          "refId": "B",
          "expr": "max(up{job=\"otel-collector\"})",
          "legendFormat": "otel-collector up"
        },
        {
          "refId": "C",
          "expr": "max(up{job=\"jaeger\"})",
          "legendFormat": "jaeger up"
        }
      ]
    }
  ]
}
